@startuml
skinparam monochrome true
skinparam defaultFontName Monospace
actor User
participant REPL
participant Parser
participant Executor
User -> REPL: input line
REPL -> Parser: tokenize/parse
Parser -> Executor: statements
Executor -> Executor: run
Executor -> REPL: output/result
REPL -> User: READY>
@enduml
